{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harne8://pose-mcp/schemas/v1/insights.json",
  "title": "POSE Insights",
  "description": "Read-only aggregation of local POSE report outcomes returned by pose_insights and pose stats --json.",
  "type": "object",
  "properties": {
    "group_by": { "type": "string", "enum": ["workflow", "task", "context"] },
    "since_days": { "type": "integer", "minimum": 0 },
    "records_scanned": { "type": "integer", "minimum": 0 },
    "records_skipped_by_window": { "type": "integer", "minimum": 0 },
    "records_skipped_invalid": { "type": "integer", "minimum": 0 },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "pass": { "type": "integer", "minimum": 0 },
          "fail": { "type": "integer", "minimum": 0 },
          "partial": { "type": "integer", "minimum": 0 },
          "skipped": { "type": "integer", "minimum": 0 },
          "unknown": { "type": "integer", "minimum": 0 },
          "total": { "type": "integer", "minimum": 0 },
          "pass_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
        },
        "required": ["key", "pass", "fail", "partial", "skipped", "unknown", "total", "pass_rate"],
        "additionalProperties": true
      }
    }
  },
  "required": ["group_by", "since_days", "records_scanned", "records_skipped_by_window", "records_skipped_invalid", "rows"],
  "additionalProperties": true
}
