#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "pose pre-commit: expected exactly one gate name" >&2
  exit 2
fi

case "$1" in
  check) pose_args=(check --strict) ;;
  lint-spec) pose_args=(lint-spec --all --strict) ;;
  history-check) pose_args=(history-check --strict) ;;
  *)
    echo "pose pre-commit: unsupported gate: $1" >&2
    exit 2
    ;;
esac

project_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "pose pre-commit: not inside a git repository" >&2
  exit 1
}
pose_executable="$project_root/pose"
if [[ ! -x "$pose_executable" ]]; then
  echo "pose pre-commit: $pose_executable is missing or not executable; install POSE first" >&2
  exit 1
fi

exec "$pose_executable" "${pose_args[@]}"
