{
  "defaults": {
    "mode": "strict"
  },
  "stacks": {
    "node": {
      "checks": [
        {
          "name": "lint",
          "program": "npm",
          "args": ["run", "lint", "--if-present"],
          "severity": "optional"
        },
        {
          "name": "test",
          "program": "npm",
          "args": ["test", "--if-present"],
          "severity": "required"
        },
        {
          "name": "build",
          "program": "npm",
          "args": ["run", "build", "--if-present"],
          "severity": "required"
        },
        {
          "name": "typecheck",
          "program": "npm",
          "args": ["run", "typecheck", "--if-present"],
          "severity": "optional"
        }
      ]
    },
    "go": {
      "checks": [
        {
          "name": "test",
          "program": "go",
          "args": ["test", "./..."],
          "severity": "required"
        },
        {
          "name": "vet",
          "program": "go",
          "args": ["vet", "./..."],
          "severity": "optional"
        }
      ]
    },
    "rust": {
      "checks": [
        {
          "name": "test",
          "program": "cargo",
          "args": ["test"],
          "severity": "required"
        }
      ]
    },
    "java": {
      "checks": [
        {
          "name": "maven-test",
          "program": "mvn",
          "args": ["-B", "test"],
          "severity": "required",
          "when": {
            "fileExists": "pom.xml"
          }
        },
        {
          "name": "gradle-test",
          "program": "./gradlew",
          "args": ["test"],
          "severity": "required",
          "when": {
            "fileExists": "gradlew"
          }
        },
        {
          "name": "gradle-test-wrapper",
          "program": "gradle",
          "args": ["test"],
          "severity": "required",
          "when": {
            "fileExists": "build.gradle",
            "fileNotExists": "gradlew"
          }
        },
        {
          "name": "gradle-test-wrapper-kts",
          "program": "gradle",
          "args": ["test"],
          "severity": "required",
          "when": {
            "fileExists": "build.gradle.kts",
            "fileNotExists": "gradlew"
          }
        }
      ]
    }
  },
  "moduleOverrides": {}
}
